# DBCheck environment variables
# This file is loaded by systemd from /opt/dbcheck/.env (chmod 640).
# Lines starting with # are comments. Do not add inline comments after values.

# ---- Storage ----------------------------------------------------------------
# SQLite database file. Default: /opt/dbcheck/data/dbcheck.db
# DBCHECK_SQLITE_PATH=/opt/dbcheck/data/dbcheck.db

# Fernet symmetric key file. Default: /opt/dbcheck/data/.fernet_key
# DBCHECK_FERNET_KEY_FILE=/opt/dbcheck/data/.fernet_key

# ---- Tencent Cloud feature flags (all ON by default) ------------------------
# Master switch for ALL Tencent Cloud API calls.
DBCHECK_TENCENT_API_ENABLED=true

# Allows DBCheck to create real Tencent Cloud backup tasks.
DBCHECK_CLOUD_BACKUP_ENABLED=true

# Enables slow-query auto-polling scheduler.
DBCHECK_SCHEDULER_ENABLED=true

# ---- Slow query scheduler (only meaningful when TENCENT_API_ENABLED=true) ---
# DBCHECK_POLL_INTERVAL=3600            # seconds between polls
# DBCHECK_SCHEDULER_CONCURRENCY=4       # max concurrent bindings
# DBCHECK_SLOW_QUERY_RETENTION_DAYS=3   # how long to keep slow-query rows

# ---- Self-hosted slow query collection --------------------------------------
# DBCHECK_SELF_HOSTED_SLOW_MIN_MS=1000      # minimum max execution time
# DBCHECK_SELF_HOSTED_SLOW_LIMIT=200        # max rows per instance per refresh
# DBCHECK_SELF_HOSTED_CONNECT_TIMEOUT=5     # connection timeout in seconds
# DBCHECK_SELF_HOSTED_SLOW_LOG_FILE_MAX_BYTES=5242880
# DBCHECK_SELF_HOSTED_PG_BUCKET_SECONDS=3600

# ---- Logging ----------------------------------------------------------------
# DBCHECK_LOG_LEVEL=INFO                # DEBUG / INFO / WARNING / ERROR
