# DBCheck environment variables
# This file is loaded by systemd from /opt/dbcheck/.env (chmod 640).
# Lines starting with # are comments. Uncomment to override a default.

# ---- Storage ----------------------------------------------------------------
# SQLite database file. Default: /opt/dbcheck/data/dbcheck.db
# DBCHECK_SQLITE_PATH=/opt/dbcheck/data/dbcheck.db

# Fernet symmetric key file. Default: /opt/dbcheck/data/.fernet_key
# DBCHECK_FERNET_KEY_FILE=/opt/dbcheck/data/.fernet_key

# ---- Tencent Cloud feature flags (all OFF by default) -----------------------
# When all three are false, the backend will NOT make any outbound calls
# to Tencent Cloud — it just answers local queries and CRUD against
# your own databases.
#
# DBCHECK_TENCENT_API_ENABLED=false   # master switch for ALL TC calls
# DBCHECK_CLOUD_BACKUP_ENABLED=false  # real cloud backup (vs. local-only)
# DBCHECK_SCHEDULER_ENABLED=false     # slow-query auto-polling

# ---- Slow query scheduler (only meaningful when TENCENT_API_ENABLED=true) ---
# DBCHECK_POLL_INTERVAL=3600            # seconds between polls
# DBCHECK_SCHEDULER_CONCURRENCY=4       # max concurrent bindings
# DBCHECK_SLOW_QUERY_RETENTION_DAYS=3   # how long to keep slow-query rows

# ---- Logging ----------------------------------------------------------------
# DBCHECK_LOG_LEVEL=INFO                # DEBUG / INFO / WARNING / ERROR
